        </mxCell>
        <mxCell id="jGSH_cQpomrff6g7vneL-64" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#d6b656;fillColor=#fff2cc;align=center;verticalAlign=middle;rounded=0;" value="Ограничением остается UI для создания задачи, где можно указать лишь &lt;br&gt;pre.txt, test.txt, solution.txt, solution-template.txt&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Сделать N-файлов? - хз может&lt;br&gt;Сделать дерево файлов? - избыточно&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="330" x="1386" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="jGSH_cQpomrff6g7vneL-65" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#d79b00;fillColor=#ffe6cc;align=center;verticalAlign=middle;rounded=0;" value="Сделать problem-template, где описано какие файлы нужны для создания задачи.&amp;nbsp;" vertex="1">
          <mxGeometry height="80" width="240" x="1431" y="1230" as="geometry" />
