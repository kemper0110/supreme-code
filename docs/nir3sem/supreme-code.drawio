        <mxCell id="jGSH_cQpomrff6g7vneL-54" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;div&gt;Как иерархию сделать&lt;/div&gt;&lt;div&gt;Family языка: js&lt;/div&gt;&lt;div&gt;Тип языка: js test case, js stdin/stdout, js function&lt;/div&gt;&lt;/div&gt;" vertex="1">
