        <mxCell id="jGSH_cQpomrff6g7vneL-57" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;А как UI создания задачи реализовать?&lt;/div&gt;&lt;div&gt;В конфиге указывать язык редактора для тестов и для задачи.&lt;/div&gt;" vertex="1">
