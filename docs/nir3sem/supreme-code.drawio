        <mxCell id="jGSH_cQpomrff6g7vneL-66" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;summary&quot;: {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;total&quot;: 5,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;passed&quot;: 4,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;failed&quot;: 1,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;skipped&quot;: 0,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;errors&quot;: 0,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;executionTimeMs&quot;: 127,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;success&quot;: false&lt;/div&gt;&lt;div&gt;&amp;nbsp; },&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;testCases&quot;: [&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;id&quot;: &quot;test_add_positive_numbers&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;name&quot;: &quot;test_add_positive_numbers&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;status&quot;: &quot;passed&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;message&quot;: null,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;errorType&quot;: null,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;errorMessage&quot;: null,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;errorDetails&quot;: null,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;executionTimeMs&quot;: 23,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;stdout&quot;: &quot;&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;stderr&quot;: &quot;&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; },&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;id&quot;: &quot;test_divide_by_zero&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;name&quot;: &quot;test_divide_by_zero&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;status&quot;: &quot;failed&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;message&quot;: &quot;AssertionError: Expected exception ZeroDivisionError not raised&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;errorType&quot;: &quot;AssertionError&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;errorMessage&quot;: &quot;Expected exception ZeroDivisionError not raised&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;errorDetails&quot;: &quot;File \&quot;solution_test.py\&quot;, line 25, in test_divide_by_zero\n&amp;nbsp; assert_raises(ZeroDivisionError, divide, 1, 0)&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;executionTimeMs&quot;: 18,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;stdout&quot;: &quot;&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;stderr&quot;: &quot;AssertionError: Expected exception ZeroDivisionError not raised\n&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; ],&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;stdout&quot;: &quot;Running 5 tests...\n&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;stderr&quot;: &quot;&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;exitCode&quot;: 1&lt;/div&gt;&lt;div style=&quot;&quot;&gt;}&lt;/div&gt;" vertex="1">
          <mxGeometry height="600" width="450" x="340" y="1040" as="geometry" />
        </mxCell>
        <mxCell id="jGSH_cQpomrff6g7vneL-68" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;div&gt;Работа тестраннера раньше:&lt;/div&gt;&lt;div&gt;1. Слушает сообщения из кафки&lt;/div&gt;&lt;div&gt;2. Ищет файлы задачи&lt;/div&gt;&lt;div&gt;3. Переключает плагины по languageId&lt;/div&gt;&lt;div&gt;4. Вызывает метод .test() с кодом решения и задачей&lt;/div&gt;&lt;div&gt;5. Возвращает в кафку результат&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Дальше в тестере:&lt;/div&gt;&lt;div&gt;1. Создать контейнер&lt;/div&gt;&lt;div&gt;2. Создать архив и закинуть в контейнер&lt;/div&gt;&lt;div&gt;3. Запустить контейнер&lt;/div&gt;&lt;div&gt;4. Вешаю обработчик логов&lt;/div&gt;&lt;div&gt;5. Запускаю таймаут и ожидаю контейнер&lt;/div&gt;&lt;div&gt;6. Ожидаю завершения одного, или другого.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Работа тестраннера сейчас:&lt;/div&gt;&lt;div&gt;...&lt;br&gt;?. Вернуть логи, результаты тестов, положить на диск.&amp;nbsp;&lt;/div&gt;&lt;div&gt;Положить еще что-то на диск.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;Что предоставляет хост:&lt;div&gt;- dockerClient&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Что предоставляет плагин:&lt;/div&gt;&lt;div&gt;- languageId для выбора плагина по&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;languageId&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;в сообщении&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="410" width="390" x="-1170" y="-150" as="geometry" />
        </mxCell>
