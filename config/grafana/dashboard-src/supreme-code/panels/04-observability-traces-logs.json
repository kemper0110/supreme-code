[
  {
    "id": 13,
    "type": "row",
    "title": "Observability: traces + logs",
    "collapsed": false,
    "panels": [],
    "gridPos": {
      "h": 1,
      "w": 24,
      "x": 0,
      "y": 59
    }
  },
  {
    "id": 25,
    "type": "table",
    "title": "Tempo traces",
    "datasource": {
      "type": "tempo",
      "uid": "tempo"
    },
    "gridPos": {
      "h": 12,
      "w": 12,
      "x": 0,
      "y": 60
    },
    "description": "TraceQL search excludes infrastructure noise from Prometheus metrics scraping and Loki push calls. Click a Trace ID cell to put it into the trace_id dashboard filter for Loki logs.",
    "fieldConfig": {
      "defaults": {
        "custom": {
          "align": "auto",
          "cellOptions": {
            "type": "auto"
          },
          "inspect": false
        },
        "mappings": [],
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            }
          ]
        }
      },
      "overrides": [
        {
          "matcher": {
            "id": "byRegexp",
            "options": "(?i)trace.*id|traceid|trace_id"
          },
          "properties": [
            {
              "id": "links",
              "value": [
                {
                  "title": "Filter Loki logs by trace_id",
                  "url": "?orgId=1&from=${__from}&to=${__to}&${application:queryparam}&${level:queryparam}&var-trace_id=${__value.raw}&var-log_search="
                }
              ]
            },
            {
              "id": "custom.cellOptions",
              "value": {
                "type": "color-text"
              }
            }
          ]
        },
        {
          "matcher": {
            "id": "byRegexp",
            "options": "(?i)duration"
          },
          "properties": [
            {
              "id": "unit",
              "value": "ms"
            },
            {
              "id": "custom.cellOptions",
              "value": {
                "type": "color-background"
              }
            },
            {
              "id": "thresholds",
              "value": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "orange",
                    "value": 500
                  },
                  {
                    "color": "red",
                    "value": 1500
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    "options": {
      "cellHeight": "sm",
      "footer": {
        "countRows": false,
        "fields": "",
        "reducer": [
          "sum"
        ],
        "show": false
      },
      "showHeader": true,
      "sortBy": [
        {
          "desc": true,
          "displayName": "Start time"
        }
      ]
    },
    "targets": [
      {
        "datasource": {
          "type": "tempo",
          "uid": "tempo"
        },
        "limit": 50,
        "query": "{ resource.service.name =~ \"${application:regex}\" && ${trace_preset:raw} && name =~ \".*${span_search:raw}.*\" && name !~ \".*(/actuator/prometheus|prometheus|/loki/api/v1/push|loki/api).*\" }",
        "queryType": "traceql",
        "refId": "A",
        "tableType": "traces"
      }
    ]
  },
  {
    "id": 7,
    "type": "logs",
    "title": "Loki logs by trace_id",
    "datasource": {
      "type": "loki",
      "uid": "loki"
    },
    "gridPos": {
      "h": 12,
      "w": 12,
      "x": 12,
      "y": 60
    },
    "description": "Logback writes trace_id into the JSON log line, so this panel parses the line and filters by the trace_id variable. Empty trace_id shows all logs.",
    "options": {
      "dedupStrategy": "none",
      "enableLogDetails": true,
      "prettifyLogMessage": true,
      "showCommonLabels": false,
      "showLabels": false,
      "showTime": true,
      "sortOrder": "Descending",
      "wrapLogMessage": true
    },
    "targets": [
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "editorMode": "code",
        "expr": "{application=~\"${application:regex}\", level=~\"${level:regex}\"} | json | trace_id=~\".*${trace_id:raw}.*\" |~ \"${log_search:raw}\"",
        "refId": "A"
      }
    ]
  },
  {
    "id": 24,
    "type": "timeseries",
    "title": "Log rate by service and level",
    "datasource": {
      "type": "loki",
      "uid": "loki"
    },
    "gridPos": {
      "h": 8,
      "w": 8,
      "x": 0,
      "y": 72
    },
    "fieldConfig": {
      "defaults": {
        "unit": "logs/s",
        "color": {
          "mode": "palette-classic"
        },
        "custom": {
          "axisBorderShow": false,
          "axisCenteredZero": false,
          "axisColorMode": "text",
          "axisLabel": "",
          "axisPlacement": "auto",
          "barAlignment": 0,
          "drawStyle": "line",
          "fillOpacity": 15,
          "gradientMode": "opacity",
          "hideFrom": {
            "legend": false,
            "tooltip": false,
            "viz": false
          },
          "insertNulls": false,
          "lineInterpolation": "linear",
          "lineWidth": 1,
          "pointSize": 5,
          "scaleDistribution": {
            "type": "linear"
          },
          "showPoints": "never",
          "spanNulls": false,
          "stacking": {
            "group": "A",
            "mode": "none"
          },
          "thresholdsStyle": {
            "mode": "off"
          }
        },
        "mappings": [],
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            },
            {
              "color": "red",
              "value": 1
            }
          ]
        }
      },
      "overrides": []
    },
    "options": {
      "legend": {
        "calcs": [
          "mean",
          "max"
        ],
        "displayMode": "table",
        "placement": "bottom",
        "showLegend": true
      },
      "tooltip": {
        "mode": "multi",
        "sort": "desc"
      }
    },
    "targets": [
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "editorMode": "code",
        "expr": "sum by (application, level) (rate({application=~\"${application:regex}\", level=~\"${level:regex}\"} |~ \"${log_search:raw}\" [1m]))",
        "legendFormat": "{{application}} {{level}}",
        "queryType": "range",
        "refId": "A"
      }
    ]
  },
  {
    "id": 26,
    "type": "bargauge",
    "title": "Noisiest error loggers (5m)",
    "datasource": {
      "type": "loki",
      "uid": "loki"
    },
    "gridPos": {
      "h": 8,
      "w": 8,
      "x": 8,
      "y": 72
    },
    "fieldConfig": {
      "defaults": {
        "color": {
          "mode": "thresholds"
        },
        "mappings": [],
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            },
            {
              "color": "orange",
              "value": 1
            },
            {
              "color": "red",
              "value": 3
            }
          ]
        },
        "unit": "short"
      },
      "overrides": []
    },
    "options": {
      "displayMode": "gradient",
      "maxVizHeight": 300,
      "minVizHeight": 16,
      "minVizWidth": 8,
      "namePlacement": "auto",
      "orientation": "horizontal",
      "reduceOptions": {
        "calcs": [
          "lastNotNull"
        ],
        "fields": "",
        "values": false
      },
      "showUnfilled": true,
      "sizing": "auto",
      "valueMode": "color"
    },
    "targets": [
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "editorMode": "code",
        "expr": "topk(5, sum by (logger) (count_over_time({application=~\"${application:regex}\", level=~\"ERROR|WARN\"} | json | logger != \"\" |~ \"${log_search:raw}\" [5m])))",
        "legendFormat": "{{logger}}",
        "queryType": "range",
        "refId": "A"
      }
    ]
  },
  {
    "id": 27,
    "type": "text",
    "title": "Demo shortcuts",
    "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
    },
    "gridPos": {
      "h": 8,
      "w": 8,
      "x": 16,
      "y": 72
    },
    "options": {
      "mode": "markdown",
      "content": "### Fast path for defense demo\n\n1. Pick **Trace preset**: slow requests, errors, or submissions.\n2. Click a **Trace ID** in the Tempo table.\n3. The Loki panel immediately narrows to log lines with that `trace_id`.\n4. Use **Log contains** for keywords like `exception`, `submission`, `kafka`, `problem`.\n\nNoise from `/actuator/prometheus` and `/loki/api/v1/push` is filtered out of the trace search."
    }
  }
]
